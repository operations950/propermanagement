DEBUG=True
SECRET_KEY=change-me
ALLOWED_HOSTS=127.0.0.1,localhost
RUN_SCHEDULER=True

# Scheduler intervals (minutes)
RECURRING_TICKET_INTERVAL_MINUTES=30
FAKE_POLL_INTERVAL_MINUTES=5
SUPPLY_DIGEST_INTERVAL_MINUTES=1440
# Simulates events against made-up demo properties — leave off now that real
# property data exists; only turn on for local dev/demo purposes.
RUN_FAKE_ADAPTER=False

# Email (console backend used in dev regardless of these)
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=noreply@example.com

# SMS (stub/log backend until a real provider is configured)
SMS_PROVIDER=log

# Vendor completion link
VENDOR_TOKEN_EXPIRY_DAYS=30

# Future integrations (not wired live yet)
GMAIL_INITIAL_SYNC_DAYS=14
GMAIL_POLL_INTERVAL_MINUTES=10
QUO_API_KEY=
# On the very first Quo sync, only look back this many days rather than the
# whole account history (which can be years of conversations).
QUO_INITIAL_SYNC_DAYS=7
# How often poll_quo runs (minutes) — independent of FAKE_POLL_INTERVAL_MINUTES.
QUO_POLL_INTERVAL_MINUTES=5
GOOGLE_CALENDAR_CREDENTIALS_PATH=
AIRBNB_API_KEY=
VRBO_API_KEY=

# Google OAuth client — used for per-staff Calendar connections AND the
# shared Gmail inbox connection (admin-only, at
# /integrations/gmail/connect/). Create an OAuth client in Google Cloud
# Console (Calendar API + Gmail API enabled) and register both redirect
# URIs shown on their respective connect pages as Authorized redirect URIs.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Property form's address picker. GOOGLE_PLACES_API_KEY: a Google Cloud API
# key (separate project/product from the OAuth client above) with the
# Places API enabled — get one at console.cloud.google.com. USPS_CLIENT_ID/
# SECRET: OAuth2 client credentials from a free developer account at
# developers.usps.com. Either left blank = the address field falls back to
# plain manual entry (no live suggestions / no "USPS verified" badge).
GOOGLE_PLACES_API_KEY=
USPS_CLIENT_ID=
USPS_CLIENT_SECRET=

# Used by intake/thread_classifier.py to read a full Quo conversation thread
# and decide whether it's actionable, before creating a ticket. Get a key at
# console.anthropic.com. Left blank = classification safely no-ops (logs and
# skips) rather than failing the whole poll_quo run.
ANTHROPIC_API_KEY=
